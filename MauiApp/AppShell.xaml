<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:pages="clr-namespace:FotoUbicacion.Pages"
       x:Class="FotoUbicacion.AppShell"
       Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <ShellContent
            Title="Cámara"
            Icon="camera.png"
            ContentTemplate="{DataTemplate pages:MainPage}"
            Route="MainPage" />
        <ShellContent
            Title="Historial"
            Icon="history.png"
            ContentTemplate="{DataTemplate pages:HistorialPage}"
            Route="HistorialPage" />
    </TabBar>

</Shell>
